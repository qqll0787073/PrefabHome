{
  "name": "prefabhome-marketplace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build --configLoader runner",
    "preview": "vite preview",
    "test": "tsx --test src/**/*.test.ts && node --test scripts/test-infrastructure/*.test.mjs",
    "verify:beta:docs": "node scripts/release/check-beta-docs.mjs",
    "verify:beta:secrets": "node scripts/release/scan-tracked-secrets.mjs",
    "verify:beta": "npm run build && npm run test && npm audit --audit-level=low && npm run verify:beta:secrets && npm run verify:beta:docs",
    "verify:production-artifact": "node scripts/release/verify-production-artifact.mjs",
    "verify:production-readiness": "node scripts/release/verify-production-readiness.mjs",
    "test:staging:safety": "node --test \"scripts/test-infrastructure/staging-safety.test.mjs\"",
    "test:staging:bootstrap": "node --test \"scripts/test-infrastructure/bootstrap-staging.test.mjs\"",
    "test:staging:smoke": "node scripts/smoke/logistics-booking-live-smoke.mjs",
    "test:staging:cleanup": "node --test \"scripts/test-infrastructure/cleanup-staging-fixture.test.mjs\"",
    "test:staging:logistics-arrangement": "node scripts/smoke/logistics-arrangement-live-smoke.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
