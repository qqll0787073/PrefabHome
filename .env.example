# Browser-safe Supabase project URL. Use local/staging values for development.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Browser publishable/anon key only. Never use a service-role key here.
VITE_SUPABASE_ANON_KEY=your-publishable-key

# Explicit local UI fallback. Must be false for staging and production.
VITE_ENABLE_MARKETPLACE_DEMO=false

# Supported values: local, staging, production.
VITE_DEPLOYMENT_ENV=local

# Local builds use safe fallbacks. Production readiness requires an explicit
# non-development version and the exact 40-character candidate commit SHA.
VITE_APP_VERSION=development
VITE_COMMIT_SHA=unknown

# Browser-safe public base URL for canonical metadata and the sitemap. Local
# development may use localhost. Production readiness requires an HTTPS URL.
VITE_PUBLIC_SITE_URL=http://localhost:5173
